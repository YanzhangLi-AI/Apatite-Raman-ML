# ====================================================
# PCA: ONLY 95% ellipses for Abiotic & Biotic
#      + Synthesis split into 3 subtypes (shape-coded points)
# ====================================================
library(tidyverse)
library(ggplot2)
# 1) Load data
apatite <- read.csv(file.choose(), stringsAsFactors = TRUE)
apatite$Attribute <- factor(
apatite$Attribute,
levels = c("Abiotic", "Synthetic", "Biotic")
)
# ---- must have No for subtype rules ----
if (!("No" %in% names(apatite))) stop("No column 'No' found. Cannot split Synthesis into 3 subtypes.")
apatite$No <- as.integer(as.character(apatite$No))
# 2) PCA features (ALL samples), drop non-feature numeric columns like No
X <- apatite %>% select(where(is.numeric)) %>% select(-No)
pca_res <- prcomp(X, center = TRUE, scale. = TRUE)
var_exp <- (pca_res$sdev^2) / sum(pca_res$sdev^2)
pc1_pct <- round(var_exp[1] * 100, 1)
pc2_pct <- round(var_exp[2] * 100, 1)
# 3) Define 3 synthesis subtypes
apatite <- apatite %>%
mutate(
Synth3 = case_when(
Attribute == "Synthetic" & No >= 130 & No <= 135 ~ "Synthetic (Amorphous)",
Attribute == "Synthetic" & No >= 170 & No <= 197 ~ "Synthetic (Carbonated)",
Attribute == "Synthetic"                         ~ "Synthetic (Others)",
TRUE ~ NA_character_
),
Synth3 = factor(
Synth3,
levels = c("Synthetic (Amorphous)", "Synthetic (Carbonated)", "Synthetic (Others)")
)
)
# (Optional) check counts
# print(apatite %>% filter(Attribute=="Synthetic") %>% count(Synth3))
# 4) PCA score df
pca_df <- tibble(
PC1 = pca_res$x[, 1],
PC2 = pca_res$x[, 2],
Attribute = apatite$Attribute,
Synth3 = apatite$Synth3
)
# 5) Plot
cols_end <- c("Abiotic" = "#5089BC", "Biotic" = "#00B050")
p <- ggplot() +
# ---- 95% ellipses ONLY (no points) for Abiotic & Biotic ----
stat_ellipse(
data = subset(pca_df, Attribute %in% c("Abiotic", "Biotic")),
mapping = aes(x = PC1, y = PC2, color = Attribute, group = Attribute),
type = "t", level = 0.95, linewidth = 0.9
) +
# ---- Synthesis points (3 subtypes) ----
geom_point(
data = subset(pca_df, Attribute == "Synthetic"),
aes(x = PC1, y = PC2, shape = Synth3,fill = Synth3),
size = 3,
stroke = 0.6,
color = "#54534D"
)+
scale_color_manual(values = cols_end, name = NULL) +
scale_shape_manual(
values = c(
"Synthetic (Amorphous)"  = 23,
"Synthetic (Carbonated)" = 24,
"Synthetic (Others)"     = 22
),
name = NULL
) +
scale_fill_manual(
values = c(
"Synthetic (Amorphous)"  = "pink",  # 浅灰
"Synthetic (Carbonated)" = "orange",  # 中灰
"Synthetic (Others)"     = "lightgray"   # 深灰
),
name = NULL
)+
labs(
x = paste0("PC1 (", pc1_pct, "%)"),
y = paste0("PC2 (", pc2_pct, "%)")
) +
theme_bw(base_size = 16) +
theme(
legend.position = "none",
panel.grid = element_blank(),
axis.text.x = element_text(size = 14),
axis.text.y = element_text(size = 14),
axis.title.x = element_text(size = 15, face = "bold"),
axis.title.y = element_text(size = 15, face = "bold")
) +
guides(
color = guide_legend(
order = 1,
override.aes = list(linewidth = 1.2)
),
shape = guide_legend(
order = 2,
override.aes = list(
color  = "#54534D",
stroke = 0.6,
size   = 3
)
)
)+
coord_cartesian(xlim = c(-6, 6), ylim = c(-4.5, 7))
print(p)
