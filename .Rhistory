# Thresholds
W5_cut <- 13.4
Y7_cut <- 0.06
# Count Biotic and Abiotic samples satisfying the condition
count_result <- apatite %>%
filter(
W5 >= W5_cut,
Y7 >= Y7_cut,
Attribute %in% c("Biotic", "Abiotic")
) %>%
count(Attribute)
print(count_result)
# ==================================================
library(ggplot2)
library(grid)  # for unit()
# =========================
# 0) Thresholds (two params)
# =========================
W5_threshold <- 13.4
Y7_threshold <- 0.06
# =========================
# 1) Example unknown data
# =========================
df_unknown <- data.frame(
Sample = c("A1","A2","A3"),
Group  = c("Type A","Type A","Type A"),
W5 = c(13.8, 7.6, 10.0),
Y7 = c(0.04, 0.07, 0.03)
)
# Known data (must contain columns: W5, Y7, Attribute)
df_known <- apatite
# =========================
# 2) Background region (top-right)
# =========================
rect_df <- data.frame(
xmin = Y7_threshold,
xmax = Inf,
ymin = W5_threshold,
ymax = Inf
)
# =========================
# 3) Plot: x=W5, y=Y7
# =========================
ggplot() +
# Background region (biogenic-like)
geom_rect(
data = rect_df,
aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax),
fill = "#F4A261",
alpha = 0.15,
inherit.aes = FALSE
) +
# Known data
geom_point(
data = df_known,
aes(x = W5, y = Y7, color = Attribute),
alpha = 0.6, size = 2
) +
# Unknown data
geom_point(
data = df_unknown,
aes(x = W5, y = Y7, shape = Group, fill = Group),
size = 4.2,
stroke = 1.2,
color = "black"
) +
scale_shape_manual(values = c("Type A" = 21)) +
scale_fill_manual(values = c("Type A" = "white")) +
# Threshold lines
geom_vline(xintercept = W5_threshold, linetype = 2, linewidth = 0.8) +
geom_hline(yintercept = Y7_threshold, linetype = 2, linewidth = 0.8) +
theme_bw(base_size = 14) +
scale_color_manual(
values = c(
"Abiotic"    = "blue",
"Synthetic"  = "gray",
"Biotic"     = "darkgreen"
)
) +
theme(
panel.grid = element_blank(),
panel.border = element_rect(color = "black", fill = NA, linewidth = 1),
axis.title = element_text(face = "bold"),
axis.text  = element_text(color = "black"),
legend.title = element_blank(),
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.ticks = element_line(color = "black", linewidth = 0.8),
axis.ticks.length = unit(4, "pt")
) +
labs(
title = "",
x = "FWHM of Band 5",
y = "Intensity of Band 7",
color = "Endmember"
)
