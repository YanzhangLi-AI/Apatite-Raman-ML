cat("  2 = Three-class PCA (331)\n")
cat("  3 = BOTH (default)\n")
choice <- suppressWarnings(as.integer(readline("Enter 1/2/3: ")))
if (!choice %in% c(1, 2, 3)) stop("Invalid choice. Please enter 1, 2, or 3.")
